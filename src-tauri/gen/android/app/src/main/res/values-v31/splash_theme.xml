<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ SplashScreen API 主题 -->
    <!-- 使用系统 SplashScreen API，国内主流手机（华为/小米/OPPO/vivo）均已支持 -->
    <style name="Theme.rapid_raw.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.rapid_raw</item>
    </style>
</resources>