<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 导入图片 -->
    <shortcut
        android:shortcutId="import_image"
        android:enabled="true"
        android:icon="@android:drawable/ic_menu_add"
        android:shortcutShortLabel="@string/shortcut_import"
        android:shortcutLongLabel="@string/shortcut_import_long">
        <intent
            android:action="io.github.CyberTimon.RapidRAW.ACTION_IMPORT"
            android:targetPackage="${applicationId}"
            android:targetClass="io.github.CyberTimon.RapidRAW.MainActivity" />
    </shortcut>

    <!-- 打开图库 -->
    <shortcut
        android:shortcutId="open_library"
        android:enabled="true"
        android:icon="@android:drawable/ic_menu_gallery"
        android:shortcutShortLabel="@string/shortcut_library"
        android:shortcutLongLabel="@string/shortcut_library_long">
        <intent
            android:action="io.github.CyberTimon.RapidRAW.ACTION_LIBRARY"
            android:targetPackage="${applicationId}"
            android:targetClass="io.github.CyberTimon.RapidRAW.MainActivity" />
    </shortcut>
</shortcuts>