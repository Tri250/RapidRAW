<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with Material You (Dynamic Color) support -->
    <style name="Theme.rapid_raw" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Material You Dynamic Color (Android 12+) -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>
        <!-- 启用 Dynamic Color (Android 12+) -->
        <item name="android:colorBackground">@color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <!-- Splash screen theme fallback for API 26-30 (API 31+ uses values-v31/splash_theme.xml) -->
    <style name="Theme.rapid_raw.SplashScreen" parent="Theme.rapid_raw">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
