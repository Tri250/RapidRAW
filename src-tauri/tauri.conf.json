{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "io.github.CyberTimon.RapidRAW",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "productName": "RapidRAW",
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "RapidRAW",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "transparent": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://* asset: http://asset.localhost https://asset.localhost; script-src 'self'",
      "dangerousDisableAssetCspModification": false,
      "capabilities": ["default"],
      "assetProtocol": {
            "enable": true,
            "scope": {
              "allow": [
                "$APPCACHE/**/*",
                "$APPLOCALDATA/**/*",
                "$APPCONFIG/**/*",
                "$APPDATA/**/*",
                "$HOME/**/*",
                "$TEMP/**/*",
                "$RESOURCE/**/*",
                "$LOG/**/*",
                "**/.local/share/**/*",
                "**/.cache/**/*",
                "**/.config/**/*"
              ],
              "requireLiteralLeadingDot": false
            }
          }
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/256x256.png", "icons/512x512.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["resources", "lensfun_db"],
    "category": "Photography",
    "fileAssociations": [
      {
        "ext": [
          "dng",
          "pro",
          "ari",
          "crw",
          "cr2",
          "cr3",
          "bay",
          "raw",
          "erf",
          "raf",
          "3fr",
          "fff",
          "iiq",
          "kdc",
          "k25",
          "dcs",
          "dcr",
          "mos",
          "rwl",
          "mef",
          "mrw",
          "nef",
          "nrw",
          "orf",
          "rw2",
          "pef",
          "ptx",
          "srw",
          "x3f",
          "arw",
          "srf",
          "sr2",
          "jpg",
          "jpeg",
          "png",
          "gif",
          "bmp",
          "tiff",
          "tif",
          "exr",
          "qoi"
        ],
        "name": "Image",
        "description": "Image file",
        "role": "Editor"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser",
        "languages": [
          "English",
          "SimpChinese",
          "TradChinese",
          "French",
          "German",
          "Italian",
          "Japanese",
          "Korean",
          "Polish",
          "Portuguese",
          "Russian",
          "Spanish"
        ]
      }
    }
  },
  "version": "1.8.20"
}
